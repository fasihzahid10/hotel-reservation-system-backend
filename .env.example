PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hotel_reservation?schema=public"
JWT_SECRET="super-secret-and-change-me"
JWT_EXPIRES_IN="12h"
FRONTEND_URL="http://localhost:3000"
COOKIE_NAME="hrs_access_token"
COOKIE_SECURE=false

# PayTabs (Hosted Payment Page) — optional. When all three credentials + API_PUBLIC_URL are set, **public** website
# bookings require PayTabs (`withPayment: true`). Staff bookings (POST /reservations with auth) stay pay-optional.
# Use your region’s API host: https://support.paytabs.com/en/support/solutions/articles/60000718070
API_PUBLIC_URL="http://localhost:4000"
PAYTABS_SERVER_KEY=""
PAYTABS_PROFILE_ID=""
PAYTABS_API_BASE="https://secure.paytabs.sa"
PAYTABS_CURRENCY="SAR"
